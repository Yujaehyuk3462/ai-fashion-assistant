rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // 현재 앱은 uid로 아이템을 구분하지 않고 모든 로그인 사용자가
    // 같은 wardrobe 컬렉션을 공유한다. 일단 "인증된 사용자만 허용"으로
    // permission-denied를 해결하되, 사용자별 데이터 분리는 별도 작업 필요.
    match /wardrobe/{itemId} {
      allow read, write: if request.auth != null;
    }

    // fitting_job_controller.dart가 가상 피팅 결과를 캐싱하는 컬렉션.
    // doc id는 사용자 사진+옷 조합의 SHA-256 해시라 개인 식별 정보가 아니다.
    match /fitting_cache/{cacheKey} {
      allow read, write: if request.auth != null;
    }

    // 체형/취향 프로필(키·몸무게·퍼스널컬러 등)은 개인 민감정보라
    // wardrobe/fitting_cache와 달리 본인 문서만 읽고 쓸 수 있게 한다.
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
  }
}
