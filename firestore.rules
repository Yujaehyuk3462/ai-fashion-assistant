rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // 현재 앱은 uid로 아이템을 구분하지 않고 모든 로그인 사용자가
    // 같은 wardrobe 컬렉션을 공유한다. 일단 "인증된 사용자만 허용"으로
    // permission-denied를 해결하되, 사용자별 데이터 분리는 별도 작업 필요.
    match /wardrobe/{itemId} {
      allow read, write: if request.auth != null;
    }

    // fitting_job_controller.dart가 가상 피팅 결과를 캐싱하는 컬렉션.
    // doc id는 사용자 사진+옷 조합의 SHA-256 해시라 개인 식별 정보가 아니다.
    match /fitting_cache/{cacheKey} {
      allow read, write: if request.auth != null;
    }

    // 체형/취향 프로필(키·몸무게·퍼스널컬러 등)은 개인 민감정보라
    // wardrobe/fitting_cache와 달리 본인 문서만 읽고 쓸 수 있게 한다.
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // 코디 사용 이력(개인화 추천용 축적 데이터) — users/{uid}와 동일하게
    // 본인 것만 읽고 쓸 수 있다. 상위 match는 서브컬렉션까지 커버하지
    // 않으므로 별도 블록이 필요하다.
    match /users/{uid}/history/{historyId} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // 능동 추천(새 옷 등록 계기로 백그라운드 생성된 코디 카드) — 동일하게
    // 본인 것만 읽고 쓸 수 있다.
    match /users/{uid}/recommendations/{recId} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // 가상 피팅 스크랩(사용자가 직접 북마크한 결과) — 동일하게 본인 것만
    // 읽고 쓸 수 있다.
    match /users/{uid}/scraps/{scrapId} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // 에이전트 활동 로그(백그라운드 행동 서사) — 동일하게 본인 것만 읽고 쓸 수 있다.
    match /users/{uid}/agent_logs/{logId} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // 착장 캘린더(OOTD 기록) — 개인 취향 데이터라 동일하게 본인 것만 읽고 쓸 수 있다.
    match /users/{uid}/calendar/{entryId} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // 에이전트 재시도 태스크(실패한 백그라운드 작업의 상태 지속성) — 동일하게
    // 본인 것만 읽고 쓸 수 있다.
    match /users/{uid}/agent_tasks/{taskId} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
  }
}
